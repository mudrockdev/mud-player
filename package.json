{
  "name": "electrobun-svelte",
  "version": "1.0.0",
  "type": "module",
  "description": "Electrobun app with Svelte and Vite HMR",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary",
    "db:generate": "drizzle-kit generate",
    "test": "bun test"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electrobun": "1.18.1"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "npm:bun-types@1.3.14",
    "@types/three": "^0.184.1",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@videojs/core": "^10.0.0-beta.23",
    "concurrently": "^9.1.0",
    "svelte": "^5.55.8",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  }
}
